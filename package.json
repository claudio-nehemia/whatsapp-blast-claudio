{
  "name": "whatsapp-blast-platform",
  "version": "1.0.0",
  "description": "WhatsApp Blast Platform - Monorepo",
  "scripts": {
    "install:all": "npm install && npm install --prefix whatsapp-service && npm install --prefix frontend",
    "dev:whatsapp": "npm run dev --prefix whatsapp-service",
    "dev:backend": "cd backend && cargo run",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently -k -p \"[{name}]\" -n \"whatsapp,backend,frontend\" -c \"cyan,magenta,green\" \"npm:dev:whatsapp\" \"npm:dev:backend\" \"npm:dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
